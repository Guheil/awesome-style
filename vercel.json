{
  "redirects": [
    {
      "source": "/",
      "destination": "/src/pages/home/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/src/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
